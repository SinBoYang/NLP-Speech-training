# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Azure Speech-to-Text (STT) Service
# 從 Azure Portal 取得這些值
# 1. 建立 "Speech" 資源
# 2. 在 "Keys and Endpoint" 中取得 Key 和 Region
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=your-azure-region-here
# 例如：eastasia, westus2, centralindia, canadacentral

# Google Generative AI (Gemini) — 用於演說分析與改寫
# 從 Google AI Studio 取得：https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key-here

# Database (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/speech_training

# Speech Language Settings (ISO 639-1 code)
# 繁體中文: zh-TW
# 簡體中文: zh-CN
# 英文: en-US
SPEECH_LANGUAGE=zh-TW
