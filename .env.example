# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Azure Speech-to-Text (STT) Service
# 從 Azure Portal 建立 "Speech" 資源後，在 "Keys and Endpoint" 中取得
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=your-azure-speech-region-here
# 例如：northcentralus, eastasia, westus2

# Azure OpenAI
# 從 Azure Portal 建立 "Azure OpenAI" 資源後取得
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name-here

# Azure Translator
# 從 Azure Portal 建立 "Translator" 資源後取得
AZURE_TRANSLATOR_KEY=your-azure-translator-key-here
AZURE_TRANSLATOR_REGION=your-azure-translator-region-here
# 例如：northeurope, eastasia, eastus

# Google Generative AI (Gemini) - Backup
# 從 Google AI Studio 取得：https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# Speech Language Settings (ISO 639-1 code)
# 繁體中文: zh-TW | 簡體中文: zh-CN | 英文: en-US
SPEECH_LANGUAGE=zh-TW
